# База данных (Railway автоматически устанавливает DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT (придумай длинный случайный секрет)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Билайн Business API
BEELINE_API_TOKEN=your-beeline-api-token

# Секрет для вебхука Билайн (любая строка)
BEELINE_WEBHOOK_SECRET=your-webhook-secret-token

# URL фронтенда (для CORS)
FRONTEND_URL=https://your-frontend.railway.app

PORT=3001
NODE_ENV=production
